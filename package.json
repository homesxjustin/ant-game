{
  "name": "simant-evolution",
  "version": "0.1.0",
  "private": true,
  "description": "SimAnt: Evolution — a portable, deterministic ant-colony simulation game core with a swappable platform layer (web / PC / console).",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "npm run build && node scripts/smoke.mjs",
    "lint": "eslint . --ext .ts"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "playwright-core": "^1.61.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vitest": "^2.0.5"
  },
  "dependencies": {
    "@types/three": "^0.185.0",
    "three": "^0.185.1"
  }
}
